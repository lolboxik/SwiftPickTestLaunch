[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NuGet
*.nupkg
*.snupkg
packages/

# Coverage
coverage/
*.coverage
*.coveragexml

# Secrets (never commit these!)
appsettings.Production.json
*.pfx
*.key
*.pem
