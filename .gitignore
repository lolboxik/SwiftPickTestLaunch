.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
*.userprefs
*.slnx

# Rider
.idea/

# Node.js (frontend)
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/build/

# Environment variables
.env
.env.local
.env.*.local

# Database
*.mdf
*.ldf
*.ndf
*.sdf

# OS files
.DS_Store
Thumbs.db

